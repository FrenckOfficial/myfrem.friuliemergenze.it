{
  "buildCommand": "",
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/api/sendLoginMail",
      "destination": "/api/sendLoginMail.js"
    },
    {
      "source": "/api/triggerNewsWorkflow",
      "destination": "/api/triggerNewsWorkflow.js"
    },
    {
      "source": "/api/triggerVehicleWorkflow",
      "destination": "/api/triggerVehicleWorkflow.js"
    }
  ],
  "headers": [
    {
      "source": "/staff/dashboard/management/(.*)/style.css",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/css; charset=utf-8"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    },
    {
      "source": "/api/sendLoginMail",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/staff/dashboard/staff",
      "destination": "/staff/dashboard",
      "permanent": true
    }
  ]
}